spring.application.name=ritmo

spring.datasource.url=${DB_URL:jdbc:h2:mem:testdb}
spring.datasource.username=${DB_USERNAME:sa}
spring.datasource.password=${DB_PASSWORD:password}
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect

# Define o prefixo global para todos os endpoints da aplicação
server.servlet.context-path=/api/v1

# Springdoc OpenApi 3.1 & Swagger 3
springdoc.swagger-ui.path=/ritmo.html
springdoc.api-docs.path=/docs-ritmo

# Ollama - Servidor local
spring.ai.ollama.base-url=${OLLAMA_URL:http://localhost:11434}
spring.ai.ollama.chat.model=llama3.2
spring.ai.ollama.chat.options.temperature=0.7
spring.ai.ollama.chat.options.num-predict=500

# Timeouts elasticos para inferencia local (LLM pode demorar 30-120s)
spring.ai.ollama.chat.options.timeout=120s
spring.ai.ollama.connection-timeout=10s
spring.ai.ollama.read-timeout=120s